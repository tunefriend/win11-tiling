{\pard \ql \f0 \sa0 \li360 \fi-360 4.\tx360\tab Assign {\b Cycle layouts} keybindings in the Keybindings section\sa180\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Change keyboard shortcuts\par}
{\pard \ql \f0 \sa180 \li0 \fi0 In Tiling Shell settings \u8594 ? {\b Keybindings}, you can customize:\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Move window left/right/up/down\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Span window across tiles\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Untile window\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Focus next/previous tiled window\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Cycle layouts\sa180\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Command-line settings (optional)\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 # Disable snap assist\line
gsettings set org.gnome.shell.extensions.tilingshell enable-snap-assist false\line
\line
# Increase gap between tiles\line
gsettings set org.gnome.shell.extensions.tilingshell inner-gaps 24\line
\line
# Enable auto-tiling for new windows\line
gsettings set org.gnome.shell.extensions.tilingshell enable-autotiling true\par}
