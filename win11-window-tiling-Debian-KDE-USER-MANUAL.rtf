{\pard \ql \f0 \sa180 \li0 \fi0 Transfer the file:\par}
{\pard \ql \f0 \sa180 \li0 \fi0 {\f1 win11-window-tiling-kde_1.0.0_all.deb}\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Step 2 \u8212- Install with dpkg\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo dpkg -i win11-window-tiling-kde_1.0.0_all.deb\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Step 3 \u8212- Fix missing dependencies (if prompted)\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo apt install -f\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Step 4 \u8212- Verify installation\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 dpkg -l win11-window-tiling-kde\par}
{\pard \ql \f0 \sa180 \li0 \fi0 Expected status: {\f1 ii} (installed ok installed)\par}
{\pard \qc \f0 \sa180 \li0 \fi0 \emdash\emdash\emdash\emdash\emdash\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel1 \b \fs32 4. First-Time Setup\par}
