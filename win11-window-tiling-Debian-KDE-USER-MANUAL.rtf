{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel1 \b \fs32 8. Troubleshooting\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 KWin not found\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo apt install plasma-workspace kwin-wayland\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Zones or shortcuts not working\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 win11-tiling-setup\par}
{\pard \ql \f0 \sa180 \li0 \fi0 Log out and back in. Check {\b System Settings \u8594 ? Shortcuts} for Meta key conflicts.\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Load KZones manually\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.loadScript \\\line
  ~/.local/share/kwin/scripts/kzones.kwinscript kzones\line
qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.runScript kzones\par}
{\pard \ql \f0 \sa180 \li0 \fi0 Use {\f1 qdbus} instead of {\f1 qdbus6} on older setups.\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 dpkg dependency errors\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo apt install -f\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Wrong edition installed\par}
{\pard \ql \f0 \sa180 \li0 \fi0 Use {\f1 win11-window-tiling-kde}, not the generic {\f1 win11-window-tiling} or GNOME-specific packages.\par}
{\pard \qc \f0 \sa180 \li0 \fi0 \emdash\emdash\emdash\emdash\emdash\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel1 \b \fs32 9. Uninstalling\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 win11-tiling-setup --uninstall\line
sudo apt remove win11-window-tiling-kde\par}
{\pard \ql \f0 \sa180 \li0 \fi0 Log out and back in.\par}
{\pard \qc \f0 \sa180 \li0 \fi0 \emdash\emdash\emdash\emdash\emdash\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel1 \b \fs32 10. Building from Source\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 cd debian-kde\line
./build.sh\line
sudo dpkg -i ../win11-window-tiling-kde_1.0.0_all.deb\line
sudo apt install -f\par}
