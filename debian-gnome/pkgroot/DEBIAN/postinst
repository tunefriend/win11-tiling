#!/bin/sh
set -e

case "$1" in
    configure)
        echo ""
        echo "  win11-window-tiling-gnome (Debian GNOME) installed!"
        echo ""
        echo "  Run 'win11-tiling-setup' to enable Tiling Shell."
        echo "  Log out and back in after setup."
        echo ""
        ;;
esac

exit 0