{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 gnome-shell not found\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo apt install gnome-shell gnome-shell-extensions\par}
