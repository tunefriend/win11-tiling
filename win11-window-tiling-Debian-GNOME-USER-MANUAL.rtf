{\pard \ql \f0 \sa180 \li0 \fi0 Transfer: {\f1 win11-window-tiling-gnome_1.0.0_all.deb}\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Step 2 \u8212- Install with dpkg\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo dpkg -i win11-window-tiling-gnome_1.0.0_all.deb\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Step 3 \u8212- Fix missing dependencies\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo apt install -f\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Step 4 \u8212- Verify\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 dpkg -l win11-window-tiling-gnome\par}
{\pard \qc \f0 \sa180 \li0 \fi0 \emdash\emdash\emdash\emdash\emdash\par}
