{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel1 \b \fs32 8. Troubleshooting\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Setup says \u8220"gnome-shell not found\u8221"\par}
{\pard \ql \f0 \sa180 \li0 \fi0 You are not running Fedora Workstation with GNOME, or {\f1 gnome-shell} is not installed:\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo dnf install gnome-shell gnome-extensions\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Extension not working after setup\par}
{\pard \ql \f0 \sa180 \li360 \fi-360 1.\tx360\tab Confirm it is enabled:\par}
{\pard \ql \f0 \sa180 \li360 \fi0 \f1 gnome-extensions enable tilingshell@ferrarodomenico.com\par}
{\pard \ql \f0 \sa180 \li360 \fi-360 2.\tx360\tab Re-run setup:\par}
{\pard \ql \f0 \sa180 \li360 \fi0 \f1 win11-tiling-setup\par}
{\pard \ql \f0 \sa180 \li360 \fi-360 3.\tx360\tab {\b Log out and back in} \u8212- required after installing any GNOME Shell extension.\sa180\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Extension shows as incompatible\par}
{\pard \ql \f0 \sa180 \li0 \fi0 Check GNOME Shell version:\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 gnome-shell --version\par}
{\pard \ql \f0 \sa180 \li0 \fi0 This package bundles Tiling Shell builds for GNOME Shell {\b 45 through 49}. If Fedora ships a newer version not yet supported, check https://github.com/domferr/tilingshell for updates.\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Super + arrow does nothing\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Open {\b Extensions \u8594 ? Tiling Shell \u8594 ? Keybindings} and verify bindings are set\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Confirm {\b Enable keybindings} is turned on\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Check for conflicts in {\b Settings \u8594 ? Keyboard \u8594 ? Keyboard Shortcuts}\sa180\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Snap Assistant does not appear\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Confirm {\b Enable snap assist} is on in Tiling Shell settings\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Drag the window firmly to the very top edge of the screen\par}
{\pard \ql \f0 \sa0 \li360 \fi-360 \bullet \tx360\tab Ensure no other extension is intercepting edge gestures\sa180\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 dnf reports dependency errors\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo dnf install gnome-shell gnome-extensions unzip\line
sudo dnf install ./win11-window-tiling-1.0.0-1.fc41.noarch.rpm\par}
{\pard \qc \f0 \sa180 \li0 \fi0 \emdash\emdash\emdash\emdash\emdash\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel1 \b \fs32 9. Uninstalling\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Remove user configuration only\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 win11-tiling-setup --uninstall\par}
{\pard \ql \f0 \sa180 \li0 \fi0 Log out and back in.\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 Remove the package entirely\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 win11-tiling-setup --uninstall\line
sudo dnf remove win11-window-tiling\par}
{\pard \qc \f0 \sa180 \li0 \fi0 \emdash\emdash\emdash\emdash\emdash\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel1 \b \fs32 10. Building from Source\par}
{\pard \ql \f0 \sa180 \li0 \fi0 On a Fedora machine with {\f1 rpm-build} installed:\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 sudo dnf install rpm-build\line
cd fedora-workstation\line
./build.sh\par}
{\pard \ql \f0 \sa180 \li0 \fi0 Output RPM:\par}
{\pard \ql \f0 \sa180 \li0 \fi0 {\f1 win11-window-tiling-1.0.0-1.fc41.noarch.rpm}\par}
{\pard \qc \f0 \sa180 \li0 \fi0 \emdash\emdash\emdash\emdash\emdash\par}
